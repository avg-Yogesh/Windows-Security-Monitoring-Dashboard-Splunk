{
  "dataSources": {
    "ds_MgCYw7Hr": {
      "type": "ds.search",
      "options": {
        "query": "index=main source=\"WinEventLog:Security\" EventCode=4726\n| table _time host Account_Name Target_Account_Name\n| rename Target_Account_Name as \"Deleted User\", Account_Name as \"Deleted By\"\n| sort - _time",
        "queryParameters": {
          "earliest": "-7d@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Deleted User search"
    },
    "ds_3cLaLjwy": {
      "type": "ds.search",
      "options": {
        "query": "index=main EventCode=4624 Logon_Type=10 | table _time host Account_Name src_ip",
        "queryParameters": {
          "earliest": "-7d@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "RDP Logins search"
    },
    "ds_guoX9bMg": {
      "type": "ds.search",
      "options": {
        "query": "index=main (EventCode=4697 OR EventCode=7045) | eval Severity=\"High\" | table _time host EventCode Service_Name Service_file_Name Service_Account Severity | sort -_time",
        "queryParameters": {
          "earliest": "-7d@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "New Services Installation search"
    },
    "ds_zkoj5Tdm": {
      "type": "ds.search",
      "options": {
        "query": "index=main source=\"WinEventLog:Security\" (EventCode=4732 OR EventCode=4720)  | eval Severity=\"Critical\" | table _time host New_Account_Account_Name Group_Name Account_Name Severity | rename New_Account_Account_Name as \"ADDED USER\", Account_Name as \"ADDED BY\" | sort -_time",
        "queryParameters": {
          "earliest": "-7d@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "User Added To Administrator Group search"
    },
    "ds_6ygTb63F": {
      "type": "ds.search",
      "options": {
        "query": "index=main source=\"WinEventLog:Security\" EventCode=4720 | eval Severity=\"High\" | table _time host New_Account_Account_Name Account_Name Severity | rename New_Account_Account_Name as \"New User\", Account_Name as \"Created BY\" | sort - _time",
        "queryParameters": {
          "earliest": "-7d@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "New User Accounts Created search"
    },
    "ds_mQnCOKcU": {
      "type": "ds.search",
      "options": {
        "query": "index=main EventCode=1 | rex field=Image \"(?<ProcessName>[^\\\\\\\\]+$$)\" | search ProcessName IN(\"powershell.exe\", \"cmd.exe\" \"wmic.exe\",\"rundll32.exe\",\"regsvr32.exe\",\"certutil.exe\",\"mshta.exe\",\"bitsadmin.exe\",\"net.exe\",\"net1.exe\") | table _time host User ProcessName ParentImage CommandLine | sort -_time",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Suspicious LOLBins Execution search"
    },
    "ds_G2AT4sOs": {
      "type": "ds.search",
      "options": {
        "query": "index=main EventCode=4625\n| stats dc(Account_Name) as UniqueUsers values(Account_Name) as TargetedUsers count as FailedAttempts by src_ip\n| where UniqueUsers > 1\n| sort - FailedAttempts",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Multiple Users Targeted By SameIP search"
    },
    "ds_8NnnYV18": {
      "type": "ds.search",
      "options": {
        "query": "index=main EventCode=1\n| rex field=Image \"(?<ProcessName>[^\\\\\\]+)$$\"\n| stats count by ProcessName\n| sort - count\n| head 10",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Top Executed Process search"
    },
    "ds_Q8ep8Cil": {
      "type": "ds.search",
      "options": {
        "query": "index=main EventCode=1 Image=\"*powershell.exe\" | search CommandLine=\"*-ence*\" OR CommandLine=\"*-EncodedCommands*\" OR CommandLine=\"*-e*\" | table _time host User CommandLine ParentImage | sort -_time",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Encoded PowerShell Detection search"
    },
    "ds_nRvWcRKu": {
      "type": "ds.search",
      "options": {
        "query": "index=main EventCode=1 Image=\"*powershell.exe\" | table _time Computer User Image CommandLine ParentImage | sort -_time",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Suspicious PowerShell Execution search"
    },
    "ds_9iQXrG6t": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4625 | bucket _time span=5m | stats count as FailedAttempts values(src_ip) as SourceIP by _time Account_Name | where FailedAttempts>=5| sort - FailedAttempts",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Potential Brute-Force Detetction search"
    },
    "ds_HMzMdZHW": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4624 | stats count by _time Logon_Type Account_Name | sort -count",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Logon Type Logins search 2"
    },
    "ds_Btn2fXYk": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4624 \n| stats count by _time Account_Name Logon_type \n|  sort -count",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Logon Type logins search"
    },
    "ds_lPqfqcCP": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4625 Source_Network_Address!=\"-\" |stats count as \"Failed Attempts\" by Source_Network_Address | sort -\"Failed Attempts\" | head 10",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Top Source IP Address_FailedLogins_ search"
    },
    "ds_cP6EWEw1": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4625 Source_Network_Address!=\"-\" |search Account_Name!=\"ANONYMOUS LOGON\" | stats count as \"Failed Attempts\" by Account_Name | sort -\"Failed Attempts\" | head 10",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Top Failed User-Account search"
    },
    "ds_IBuCA61J": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" (EventCode=4625 OR EventCode=4624) | eval AuthenticationStatus=case(EventCode=4624,\"Successful\",EventCode=4625,\"Failed\") | timechart span=5m count by AuthenticationStatus",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Authentication Activity Trend search"
    },
    "ds_gez7PbTp": {
      "type": "ds.search",
      "options": {
        "query": "index=* host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4672| table _time ComputerName Account_Name privilege",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Privilege Assigned User search"
    },
    "ds_vtIM1KFh": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4740 | table _time ComputerName Account_Locked_Out_Name CallerComputerName",
        "queryParameters": {
          "earliest": "-7d@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Locked-out User search"
    },
    "ds_8fxIPUiv": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4740 | stats count as \"Account Lockouts\"",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Account Lockouts search"
    },
    "ds_sBe8LgP4": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4625 | stats count as \"Failed Logins\"",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Failed Logins search"
    },
    "ds_alZxeV3a": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4624 | stats count as \"Successful Logins\"",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Successful Logins search"
    },
    "ds_ViaOUsTw": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" (EventCode=4625 OR EventCode=4624) | stats count as \"Authentication Attempts\"",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Total Authentication Attempts search"
    },
    "ds_Y0cQojQ0": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" EventCode=4625 | top Account_Name",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Top Failed Users search"
    },
    "ds_HWbbkgOH": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" (EventCode=4624 OR EventCode=4625) | eval Status = if(EventCode=4624,\"Success Logins\",\"Failed Attempts\") | stats count by Status",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Success vs Failed search"
    },
    "ds_HLOWCuzc": {
      "type": "ds.search",
      "options": {
        "query": "host=\"window10-Target\" source=\"WinEventLog:Security\" (EventCode=4624 OR EventCode=4625) | timechart span=1h count by EventCode",
        "queryParameters": {
          "earliest": "-24h@h",
          "latest": "now",
          "sampleRatio": 1
        }
      },
      "name": "Login Trend - Column chart search"
    }
